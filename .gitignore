cat > .gitignore << 'EOF'
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Word temp files
~$*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
.venv/
venv/
*.pyc

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Output / data (large files)
output/
output.json

# AWS credentials
.aws/
credentials

# IDE
.vscode/
.idea/
EOF